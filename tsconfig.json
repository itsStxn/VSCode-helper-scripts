{
	"compilerOptions": {
		"rootDir": "./",
		"outDir": "dist/",
		"target": "ES2022",
		"module": "NodeNext",
		"types": ["node"],
		"moduleResolution": "NodeNext",
		"allowJs": false,
		"checkJs": false,
		"noEmit": true,
		"strict": false,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["**/*.ts"]
}
